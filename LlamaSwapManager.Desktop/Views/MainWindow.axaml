<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LlamaSwapManager.ViewModels"
        xmlns:models="using:LlamaSwapManager.Models"
        xmlns:conv="using:LlamaSwapManager.Converters"
        x:Class="LlamaSwapManager.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Llama Swap Manager"
        Icon="avares://LlamaSwapManager.Desktop/Assets/llama.ico"
        Width="1320"
        Height="860"
        MinWidth="1080"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="#0B0B12">

  <Design.DataContext>
    <vm:MainViewModel />
  </Design.DataContext>

  <Grid ColumnDefinitions="232,*" RowDefinitions="Auto,*">
    <!-- TOP BAR -->
    <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Height="56"
            Background="#0C0C14" BorderBrush="#1A1A28" BorderThickness="0,0,0,1" ZIndex="5">
      <DockPanel Margin="16,0">
        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center" DockPanel.Dock="Left">
          <Border Width="32" Height="32" CornerRadius="9" Background="#1A1A28">
            <TextBlock Text="🦙" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <StackPanel Spacing="0" VerticalAlignment="Center">
            <TextBlock Text="LlamaSwap Manager" FontSize="14" FontWeight="SemiBold" Foreground="#CDD6F4"/>
            <TextBlock Text="local orchestrator" FontSize="10" Foreground="#585B70"/>
          </StackPanel>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Center">
          <Border Background="#161622" CornerRadius="20" Padding="12,6" BorderBrush="#252536" BorderThickness="1">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Ellipse Width="8" Height="8" Fill="{Binding StatusColor}" VerticalAlignment="Center"/>
              <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="{Binding StatusColor}" VerticalAlignment="Center"/>
            </StackPanel>
          </Border>
          <Button Content="Start" Command="{Binding StartCommand}" Classes="success" Padding="14,7" IsEnabled="{Binding StartButtonEnabled}"/>
          <Button Content="Stop" Command="{Binding StopCommand}" Classes="danger" Padding="14,7" IsEnabled="{Binding StopButtonEnabled}"/>
          <Button Content="Restart" Command="{Binding RestartCommand}" Classes="warning" Padding="14,7" IsEnabled="{Binding RestartButtonEnabled}"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- SIDEBAR -->
    <Border Grid.Row="1" Grid.Column="0" Background="#0C0C14" BorderBrush="#1A1A28" BorderThickness="0,0,1,0">
      <DockPanel>
        <StackPanel DockPanel.Dock="Top" Margin="0,14,0,0" Spacing="2">
          <TextBlock Text="WORKSPACE" Classes="nav-section"/>
          <Button Command="{Binding NavigateToModelsCommand}" Classes="nav" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="8,2">
            <DockPanel>
              <Border Classes="nav-indicator" DockPanel.Dock="Left" VerticalAlignment="Center"
                      IsVisible="{Binding CurrentView, Converter={x:Static conv:StringEqualsConverter.Instance}, ConverterParameter=models}"/>
              <TextBlock Text="Models" Classes="nav-label" VerticalAlignment="Center"/>
            </DockPanel>
          </Button>
          <Button Command="{Binding NavigateToMatrixCommand}" Classes="nav" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="8,2">
            <DockPanel>
              <Border Classes="nav-indicator" DockPanel.Dock="Left" VerticalAlignment="Center"
                      IsVisible="{Binding CurrentView, Converter={x:Static conv:StringEqualsConverter.Instance}, ConverterParameter=matrix}"/>
              <TextBlock Text="Matrix" Classes="nav-label" VerticalAlignment="Center"/>
            </DockPanel>
          </Button>
          <Button Command="{Binding NavigateToMetricsCommand}" Classes="nav" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="8,2">
            <DockPanel>
              <Border Classes="nav-indicator" DockPanel.Dock="Left" VerticalAlignment="Center"
                      IsVisible="{Binding CurrentView, Converter={x:Static conv:StringEqualsConverter.Instance}, ConverterParameter=metrics}"/>
              <TextBlock Text="Metrics" Classes="nav-label" VerticalAlignment="Center"/>
            </DockPanel>
          </Button>
          <Button Command="{Binding NavigateToConfigPreviewCommand}" Classes="nav" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="8,2">
            <DockPanel>
              <Border Classes="nav-indicator" DockPanel.Dock="Left" VerticalAlignment="Center"
                      IsVisible="{Binding CurrentView, Converter={x:Static conv:StringEqualsConverter.Instance}, ConverterParameter=preview}"/>
              <TextBlock Text="Config Preview" Classes="nav-label" VerticalAlignment="Center"/>
            </DockPanel>
          </Button>
          <TextBlock Text="SYSTEM" Classes="nav-section" Margin="18,18,0,6"/>
          <Button Command="{Binding NavigateToUpdatesCommand}" Classes="nav" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="8,2">
            <DockPanel>
              <Border Classes="nav-indicator" DockPanel.Dock="Left" VerticalAlignment="Center"
                      IsVisible="{Binding CurrentView, Converter={x:Static conv:StringEqualsConverter.Instance}, ConverterParameter=updates}"/>
              <TextBlock Text="Updates" Classes="nav-label" VerticalAlignment="Center"/>
            </DockPanel>
          </Button>
          <Button Command="{Binding NavigateToSettingsCommand}" Classes="nav" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="8,2">
            <DockPanel>
              <Border Classes="nav-indicator" DockPanel.Dock="Left" VerticalAlignment="Center"
                      IsVisible="{Binding CurrentView, Converter={x:Static conv:StringEqualsConverter.Instance}, ConverterParameter=settings}"/>
              <TextBlock Text="Settings" Classes="nav-label" VerticalAlignment="Center"/>
            </DockPanel>
          </Button>
        </StackPanel>
        <Border DockPanel.Dock="Bottom" Padding="14" BorderBrush="#1A1A28" BorderThickness="0,1,0,0">
          <StackPanel Spacing="4">
            <TextBlock Text="RUNTIME" FontSize="10" FontWeight="Bold" Foreground="#585B70"/>
            <TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="#A6ADC8" TextWrapping="Wrap"/>
          </StackPanel>
        </Border>
        <Border/>
      </DockPanel>
    </Border>

    <!-- CONTENT -->
    <Border Grid.Row="1" Grid.Column="1" Background="#101018">
      <Panel>
        <Panel IsVisible="{Binding CurrentView, Converter={x:Static conv:StringEqualsConverter.Instance}, ConverterParameter=models}">

        <Grid>
          <!-- LIST FIRST -->
          <Grid RowDefinitions="Auto,*">
            <Border Grid.Row="0" Padding="24,18" BorderBrush="#1F1F2E" BorderThickness="0,0,0,1">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="4">
                  <TextBlock Text="Models" FontSize="20" FontWeight="SemiBold" Foreground="#CDD6F4"/>
                  <TextBlock Text="Profiles for llama-server. Click a card to edit — create flows stay modal." FontSize="12" Foreground="#6C7086"/>
                </StackPanel>
                <Button Grid.Column="1" Content="+ Add model" Command="{Binding AddModelCommand}"
                        Classes="success" Padding="14,8" VerticalAlignment="Center"
                        IsEnabled="{Binding CanAddModel}"/>
              </Grid>
            </Border>
            <Panel Grid.Row="1">
            <!-- Empty state -->
            <Border IsVisible="{Binding Models.Count, Converter={x:Static conv:CountToBoolConverter.Instance}, ConverterParameter=zero}"
                    Margin="24" HorizontalAlignment="Center" VerticalAlignment="Center">
              <StackPanel Spacing="12" HorizontalAlignment="Center" MaxWidth="420">
                <Border Width="64" Height="64" CornerRadius="16" Background="#161622" HorizontalAlignment="Center">
                  <TextBlock Text="🦙" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="No models yet" FontSize="18" FontWeight="SemiBold" Foreground="#CDD6F4" HorizontalAlignment="Center"/>
                <TextBlock Text="Add a llama-server profile to start routing through llama-swap. You can clone later for experiments."
                           FontSize="12" Foreground="#6C7086" TextWrapping="Wrap" TextAlignment="Center"/>
                <Button Content="+ Add your first model" Command="{Binding AddModelCommand}" Classes="success"
                        Padding="16,10" HorizontalAlignment="Center" IsEnabled="{Binding CanAddModel}"/>
              </StackPanel>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16"
                          IsVisible="{Binding Models.Count, Converter={x:Static conv:CountToBoolConverter.Instance}}">
              <ItemsControl ItemsSource="{Binding Models}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel/>
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:ModelEditItem">
                    <Border Width="300" Classes="card" Margin="8" Cursor="Hand"
                            PointerReleased="OnModelItemClick"
                            Background="{Binding IsSelected, Converter={x:Static conv:SelectedModelBrushConverter.Instance}}">
                      <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding ModelId}" FontSize="14" FontWeight="Bold" Foreground="#CDD6F4" TextTrimming="CharacterEllipsis"/>
                        <Button Grid.Row="0" Grid.Column="1" Content="Clone" Classes="ghost" Padding="8,3" FontSize="11"
                                ToolTip.Tip="Clone for parameter experiments"
                                PointerPressed="OnCloneModelPointerPressed" Click="OnCloneModelClick"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding Name}" FontSize="12" Foreground="#A6ADC8" Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding CmdPreview}" FontSize="11" Foreground="#6C7086" TextWrapping="Wrap" MaxHeight="48" TextTrimming="CharacterEllipsis" Margin="0,8,0,0"/>
                        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="6" Margin="0,12,0,0">
                          <Border Classes="pill"><TextBlock Text="{Binding Ttl, StringFormat=TTL {0}}" FontSize="10" Foreground="#89B4FA"/></Border>
                          <Border Classes="pill" IsVisible="{Binding UseJinja}"><TextBlock Text="jinja" FontSize="10" Foreground="#A6E3A1"/></Border>
                          <Border Classes="pill"><TextBlock Text="{Binding Reasoning}" FontSize="10" Foreground="#FAB387"/></Border>
                        </StackPanel>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
            </Panel>
          </Grid>

          <!-- EDITOR MODAL -->
          <Grid IsVisible="{Binding HasSelectedModel}" ZIndex="40">
            <Border Background="#CC000000" PointerPressed="OnModelEditorBackdropPressed"/>
            <Border Margin="36,24" MaxWidth="1180"
                    Background="#12121C" BorderBrush="#2A2A3D" BorderThickness="1" CornerRadius="16"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
              <Grid RowDefinitions="Auto,*,Auto">
                <Border Grid.Row="0" Padding="18,14" BorderBrush="#1F1F2E" BorderThickness="0,0,0,1">
                  <DockPanel>
                    <StackPanel Spacing="2">
                      <TextBlock Text="EDIT MODEL" FontSize="10" FontWeight="Bold" Foreground="#585B70"/>
                      <TextBlock Text="{Binding SelectedModel.ModelId}" FontSize="16" FontWeight="SemiBold" Foreground="#CDD6F4"/>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                      <Button Content="Close" Command="{Binding CloseModelEditorCommand}" Classes="ghost" Padding="12,6"/>
                    </StackPanel>
                  </DockPanel>
                </Border>
                <ScrollViewer Grid.Row="1" Padding="20" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                  <StackPanel Spacing="16" Margin="0,0,0,24">

                    <!-- ESSENTIALS (always visible) -->
                    <Border Classes="card" Padding="16">
                      <StackPanel Spacing="14">
                        <StackPanel Spacing="2">
                          <TextBlock Text="Essentials" FontSize="14" FontWeight="SemiBold" Foreground="#CDD6F4"/>
                          <TextBlock Text="What you usually change. Advanced knobs live in the sections below." FontSize="11" Foreground="#6C7086" TextWrapping="Wrap"/>
                        </StackPanel>

                        <Grid ColumnDefinitions="160,*,160,*" RowSpacing="12" ColumnSpacing="12">
                          <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                          </Grid.RowDefinitions>

                          <TextBlock Grid.Row="0" Grid.Column="0" Text="Model ID" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center"/>
                          <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SelectedModel.ModelId}" PlaceholderText="e.g. qwen2.5-14b"/>
                          <TextBlock Grid.Row="0" Grid.Column="2" Text="Display Name" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center"/>
                          <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding SelectedModel.Name}" PlaceholderText="Friendly label"/>

                          <TextBlock Grid.Row="1" Grid.Column="0" Text="Model Source" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center"/>
                          <Grid Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <TextBox Grid.Column="0" Text="{Binding SelectedModelSourceLabel}" IsReadOnly="True"/>
                            <Button Grid.Column="1" Content="Choose…" Click="OnChooseModelClick" Classes="ghost" Padding="12,6"/>
                          </Grid>

                          <TextBlock Grid.Row="2" Grid.Column="0" Text="Server Path" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center"/>
                          <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding SelectedModel.LlamaServerPath}" PlaceholderText="/path/to/llama-server"/>

                          <TextBlock Grid.Row="3" Grid.Column="0" Text="Context Size" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center"/>
                          <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding SelectedModel.ContextSize}" PlaceholderText="0 = model default" ToolTip.Tip="--ctx-size"/>
                          <TextBlock Grid.Row="3" Grid.Column="2" Text="GPU Layers" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center"/>
                          <ComboBox Grid.Row="3" Grid.Column="3"
                                    ItemsSource="{Binding GpuLayersOptions}"
                                    SelectedItem="{Binding SelectedModel.GpuLayers}"
                                    IsEditable="True"
                                    PlaceholderText="auto | all | 0 | N"
                                    ToolTip.Tip="--gpu-layers / -ngl"/>

                          <TextBlock Grid.Row="4" Grid.Column="0" Text="Reasoning" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center"/>
                          <ComboBox Grid.Row="4" Grid.Column="1"
                                    ItemsSource="{Binding ReasoningOptions}"
                                    SelectedItem="{Binding SelectedModel.Reasoning}"
                                    ToolTip.Tip="--reasoning: off is explicit in config"/>
                          <TextBlock Grid.Row="4" Grid.Column="2" Text="TTL (s)" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center"/>
                          <TextBox Grid.Row="4" Grid.Column="3" Text="{Binding SelectedModel.Ttl}" PlaceholderText="0 = never"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Spacing="16">
                          <CheckBox IsChecked="{Binding SelectedModel.UseJinja}" Content="jinja chat template engine" Foreground="#CDD6F4"/>
                          <CheckBox IsChecked="{Binding SelectedModel.FitOn}" Content="--fit on" Foreground="#CDD6F4"/>
                          <CheckBox IsChecked="{Binding SelectedModel.NoMmap}" Content="--no-mmap" Foreground="#CDD6F4"/>
                        </StackPanel>
                      </StackPanel>
                    </Border>

                    <!-- Metadata (collapsed) -->
                    <Expander Header="Name · description · aliases · host/port" IsExpanded="False" Margin="0,4,0,0">
                      <Border Classes="card" Margin="0,8,0,0" Padding="16">
                        <Grid ColumnDefinitions="160,*,160,*" RowSpacing="10" ColumnSpacing="12">
                          <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                          </Grid.RowDefinitions>
                          <TextBlock Grid.Row="0" Grid.Column="0" Text="Description" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center"/>
                          <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding SelectedModel.Description}" PlaceholderText="Optional"/>
                          <TextBlock Grid.Row="1" Grid.Column="0" Text="Aliases" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center"/>
                          <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding SelectedModel.AliasesText}" PlaceholderText="short names, comma-separated"/>
                          <TextBlock Grid.Row="2" Grid.Column="0" Text="Host" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center"/>
                          <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SelectedModel.Host}" PlaceholderText="127.0.0.1"/>
                          <TextBlock Grid.Row="2" Grid.Column="2" Text="Port" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center"/>
                          <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding SelectedModel.Port}" PlaceholderText="${PORT}"/>
                        </Grid>
                      </Border>
                    </Expander>

                    <Expander Header="Runtime · batch · threads" IsExpanded="False" Margin="0,2,0,0">
                      <Border Classes="card" Margin="0,8,0,0" Padding="14">
                        <StackPanel Spacing="10">
<StackPanel Margin="12" Spacing="12">
                              <Grid ColumnDefinitions="160,*,160,*" RowSpacing="10" ColumnSpacing="12">
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Context Size" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center" />
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SelectedModel.ContextSize}" PlaceholderText="0 = model default" ToolTip.Tip="--ctx-size / -c: prompt context size." />
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Predict Tokens" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center" />
                                <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding SelectedModel.Predict}" PlaceholderText="-1 = infinity" ToolTip.Tip="--predict: maximum generated tokens." />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Threads" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center" />
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding SelectedModel.Threads}" PlaceholderText="-1 = auto" ToolTip.Tip="--threads: CPU generation threads." />
                              </Grid>
                              <Expander Header="Advanced runtime / batching" IsExpanded="False">
                                <Grid Margin="0,8,0,0" ColumnDefinitions="160,*,160,*" RowSpacing="10" ColumnSpacing="12">
                                  <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                  <TextBlock Grid.Row="0" Grid.Column="0" Text="Threads Batch" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center" />
                                  <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SelectedModel.ThreadsBatch}" PlaceholderText="same as threads" ToolTip.Tip="--threads-batch: CPU prompt/batch processing threads." />
                                  <TextBlock Grid.Row="0" Grid.Column="2" Text="Batch Size" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center" />
                                  <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding SelectedModel.BatchSize}" PlaceholderText="2048" ToolTip.Tip="--batch-size: logical max batch size." />
                                  <TextBlock Grid.Row="1" Grid.Column="0" Text="uBatch Size" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center" />
                                  <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding SelectedModel.UBatchSize}" PlaceholderText="512" ToolTip.Tip="--ubatch-size: physical micro-batch size." />
                                </Grid>
                              </Expander>
                            </StackPanel>
                        </StackPanel>
                      </Border>
                    </Expander>

                    <Expander Header="GPU · memory · devices" IsExpanded="False" Margin="0,2,0,0">
                      <Border Classes="card" Margin="0,8,0,0" Padding="14">
                        <StackPanel Spacing="10">
<StackPanel Margin="12" Spacing="12">
                              <Grid ColumnDefinitions="160,*,160,*" RowSpacing="10" ColumnSpacing="12">
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="GPU Layers" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center" />
                                <ComboBox Grid.Row="0" Grid.Column="1"
                                          ItemsSource="{Binding GpuLayersOptions}"
                                          SelectedItem="{Binding SelectedModel.GpuLayers}"
                                          IsEditable="True"
                                          HorizontalAlignment="Stretch"
                                          PlaceholderText="auto | all | 0 | N"
                                          ToolTip.Tip="--gpu-layers / -ngl: auto, all, 0, or exact layer count (e.g. 40)." />
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Flash Attention" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center" />
                                <ComboBox Grid.Row="0" Grid.Column="3" ItemsSource="{Binding AutoOnOffOptions}" SelectedItem="{Binding SelectedModel.FlashAttention}" ToolTip.Tip="--flash-attn: auto/on/off." />
                                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal" Spacing="24">
                                  <CheckBox IsChecked="{Binding SelectedModel.FitOn}" Content="--fit on" Foreground="#CDD6F4" ToolTip.Tip="Fit unset options into device memory." />
                                  <CheckBox IsChecked="{Binding SelectedModel.NoMmap}" Content="--no-mmap" Foreground="#CDD6F4" ToolTip.Tip="Disable memory-mapped model loading." />
                                </StackPanel>
                              </Grid>
                              <Expander Header="Advanced GPU placement / memory" IsExpanded="False">
                                <Grid Margin="0,8,0,0" ColumnDefinitions="160,*,160,*" RowSpacing="10" ColumnSpacing="12">
                                  <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                  <TextBlock Grid.Row="0" Grid.Column="0" Text="Device" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center" />
                                  <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SelectedModel.Device}" PlaceholderText="CUDA0,Metal,none" ToolTip.Tip="--device: comma-separated devices; empty uses default." />
                                  <TextBlock Grid.Row="0" Grid.Column="2" Text="Split Mode" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center" />
                                  <ComboBox Grid.Row="0" Grid.Column="3" ItemsSource="{Binding SplitModeOptions}" SelectedItem="{Binding SelectedModel.SplitMode}" ToolTip.Tip="--split-mode: how to split model work across multiple GPUs." />
                                  <TextBlock Grid.Row="1" Grid.Column="0" Text="Tensor Split" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center" />
                                  <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding SelectedModel.TensorSplit}" PlaceholderText="3,1" ToolTip.Tip="--tensor-split: GPU split proportions, e.g. 3,1." />
                                  <TextBlock Grid.Row="1" Grid.Column="2" Text="Main GPU" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center" />
                                  <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding SelectedModel.MainGpu}" PlaceholderText="0" ToolTip.Tip="--main-gpu: primary GPU index." />
                                  <CheckBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4" IsChecked="{Binding SelectedModel.Mlock}" Content="--mlock (keep model in RAM)" Foreground="#CDD6F4" />
                                </Grid>
                              </Expander>
                            </StackPanel>
                        </StackPanel>
                      </Border>
                    </Expander>

                    <Expander Header="KV cache" IsExpanded="False" Margin="0,2,0,0">
                      <Border Classes="card" Margin="0,8,0,0" Padding="14">
                        <StackPanel Spacing="10">
<StackPanel Margin="12" Spacing="12">
                              <TextBlock Text="Leave empty for defaults." FontSize="11" Foreground="#A6ADC8" TextWrapping="Wrap" />
                              <Grid ColumnDefinitions="160,*,160,*" RowSpacing="10" ColumnSpacing="12">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Cache Type K" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center" />
                                <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding CacheTypeOptions}" SelectedItem="{Binding SelectedModel.CacheTypeK}" ToolTip.Tip="--cache-type-k: KV cache K datatype." />
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Cache Type V" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center" />
                                <ComboBox Grid.Row="0" Grid.Column="3" ItemsSource="{Binding CacheTypeOptions}" SelectedItem="{Binding SelectedModel.CacheTypeV}" ToolTip.Tip="--cache-type-v: KV cache V datatype." />
                              </Grid>
                              <Expander Header="Advanced cache flags" IsExpanded="False">
                                <TextBlock Margin="0,8,0,0" Text="Other cache flags go in Advanced." FontSize="11" Foreground="#A6ADC8" TextWrapping="Wrap" />
                              </Expander>
                            </StackPanel>
                        </StackPanel>
                      </Border>
                    </Expander>

                    <Expander Header="Sampling" IsExpanded="False" Margin="0,2,0,0">
                      <Border Classes="card" Margin="0,8,0,0" Padding="14">
                        <StackPanel Spacing="10">
<StackPanel Margin="12" Spacing="12">
                              <Grid ColumnDefinitions="160,*,160,*" RowSpacing="10" ColumnSpacing="12">
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Temperature" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center" />
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SelectedModel.Temperature}" PlaceholderText="0.8" ToolTip.Tip="--temp: sampling randomness." />
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Top K" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center" />
                                <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding SelectedModel.TopK}" PlaceholderText="40" ToolTip.Tip="--top-k: top-k sampling; 0 disables." />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Top P" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center" />
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding SelectedModel.TopP}" PlaceholderText="0.95" ToolTip.Tip="--top-p: nucleus sampling; 1 disables." />
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="Min P" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center" />
                                <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding SelectedModel.MinP}" PlaceholderText="0.05" ToolTip.Tip="--min-p: minimum probability sampling." />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Repeat Penalty" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center" />
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SelectedModel.RepeatPenalty}" PlaceholderText="1.0" ToolTip.Tip="--repeat-penalty: 1.0 disables." />
                              </Grid>
                              <Expander Header="Advanced sampling" IsExpanded="False">
                                <StackPanel Margin="0,8,0,0" Spacing="10">
                                  <Grid ColumnDefinitions="160,*,160,*" RowSpacing="10" ColumnSpacing="12">
                                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Presence Penalty" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center" />
                                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SelectedModel.PresencePenalty}" PlaceholderText="0" ToolTip.Tip="--presence-penalty: 0 disables." />
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Frequency Penalty" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center" />
                                    <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding SelectedModel.FrequencyPenalty}" PlaceholderText="0" ToolTip.Tip="--frequency-penalty: 0 disables." />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Repeat Last N" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center" />
                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding SelectedModel.RepeatLastN}" PlaceholderText="64" ToolTip.Tip="--repeat-last-n: tokens considered for repetition penalty." />
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Seed" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center" />
                                    <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding SelectedModel.Seed}" PlaceholderText="-1 random" />
                                  </Grid>
                                  <Grid ColumnDefinitions="160,*" RowSpacing="10">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Samplers" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center" />
                                    <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding CommonSamplersOptions}" SelectedItem="{Binding SelectedModel.Samplers}" IsEditable="True" ToolTip.Tip="--samplers: order separated by semicolons. Editable." />
                                  </Grid>
                                </StackPanel>
                              </Expander>
                            </StackPanel>
                        </StackPanel>
                      </Border>
                    </Expander>

                    <Expander Header="Server · API · endpoints" IsExpanded="False" Margin="0,2,0,0">
                      <Border Classes="card" Margin="0,8,0,0" Padding="14">
                        <StackPanel Spacing="10">
<StackPanel Margin="12" Spacing="12">
                              <Grid ColumnDefinitions="160,*,160,*" RowSpacing="10" ColumnSpacing="12">
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Parallel Slots" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center" />
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SelectedModel.Parallel}" PlaceholderText="-1 = auto" ToolTip.Tip="--parallel: number of server slots." />
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Timeout" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center" />
                                <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding SelectedModel.Timeout}" PlaceholderText="3600" ToolTip.Tip="--timeout: server read/write timeout seconds." />
                                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal" Spacing="18">
                                  <CheckBox IsChecked="{Binding SelectedModel.ContBatching}" Content="continuous batching" Foreground="#CDD6F4" />
                                  <CheckBox IsChecked="{Binding SelectedModel.Slots}" Content="slots endpoint" Foreground="#CDD6F4" />
                                </StackPanel>
                              </Grid>
                              <Expander Header="Advanced endpoints / auth" IsExpanded="False">
                                <Grid Margin="0,8,0,0" ColumnDefinitions="160,*,160,*" RowSpacing="10" ColumnSpacing="12">
                                  <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                  <TextBlock Grid.Row="0" Grid.Column="0" Text="HTTP Threads" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center" />
                                  <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SelectedModel.ThreadsHttp}" PlaceholderText="-1" ToolTip.Tip="--threads-http: HTTP request threads." />
                                  <TextBlock Grid.Row="0" Grid.Column="2" Text="API Key" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center" />
                                  <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding SelectedModel.ApiKey}" PasswordChar="*" PlaceholderText="optional" />
                                  <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal" Spacing="18">
                                    <CheckBox IsChecked="{Binding SelectedModel.Embeddings}" Content="embeddings" Foreground="#CDD6F4" />
                                    <CheckBox IsChecked="{Binding SelectedModel.Reranking}" Content="reranking" Foreground="#CDD6F4" />
                                    <CheckBox IsChecked="{Binding SelectedModel.Metrics}" Content="metrics" Foreground="#CDD6F4" />
                                    <CheckBox IsChecked="{Binding SelectedModel.PropsEndpoint}" Content="props" Foreground="#CDD6F4" />
                                  </StackPanel>
                                </Grid>
                              </Expander>
                            </StackPanel>
                        </StackPanel>
                      </Border>
                    </Expander>

                    <Expander Header="Chat template · reasoning format" IsExpanded="False" Margin="0,2,0,0">
                      <Border Classes="card" Margin="0,8,0,0" Padding="14">
                        <StackPanel Spacing="10">
<StackPanel Margin="12" Spacing="12">
                              <Grid ColumnDefinitions="160,*,160,*" RowSpacing="10" ColumnSpacing="12">
                                <Grid.RowDefinitions>
                                  <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <CheckBox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                                          IsChecked="{Binding SelectedModel.UseJinja}"
                                          Content="--jinja"
                                          Foreground="#CDD6F4"
                                          VerticalAlignment="Center" />
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Reasoning" FontSize="12"
                                           Foreground="#A6ADC8" VerticalAlignment="Center" />
                                <ComboBox Grid.Row="0" Grid.Column="3"
                                          ItemsSource="{Binding ReasoningOptions}"
                                          SelectedItem="{Binding SelectedModel.Reasoning}"
                                          HorizontalAlignment="Stretch"
                                          ToolTip.Tip="--reasoning: off forces no thinking and MUST be explicit in cmd. Empty uses model/server default (often thinking-capable). New models default to off." />
                              </Grid>
                              <Expander Header="Advanced chat template / reasoning" IsExpanded="False">
                                <Grid Margin="0,8,0,0" ColumnDefinitions="160,*" RowSpacing="10">
                                  <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                  </Grid.RowDefinitions>
                                  <TextBlock Grid.Row="0" Grid.Column="0" Text="Chat Template" FontSize="12"
                                             Foreground="#A6ADC8" VerticalAlignment="Center" />
                                  <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                    <ComboBox ItemsSource="{Binding ChatTemplatePresets}"
                                              SelectedItem="{Binding SelectedModel.ChatTemplate}"
                                              IsEditable="True"
                                              HorizontalAlignment="Stretch"
                                              PlaceholderText="name · path/to.jinja · or Jinja string"
                                              ToolTip.Tip="--chat-template: built-in name (chatml, llama3…), path to .jinja file, or raw Jinja template string. Empty = model default." />
                                    <TextBlock Text="Built-in name (chatml, llama3…), path to a .jinja file, or raw Jinja. Leave empty for the model default."
                                               FontSize="10" Foreground="#6C7086" TextWrapping="Wrap" />
                                  </StackPanel>
                                  <TextBlock Grid.Row="1" Grid.Column="0" Text="Reasoning Format" FontSize="12"
                                             Foreground="#A6ADC8" VerticalAlignment="Center" />
                                  <ComboBox Grid.Row="1" Grid.Column="1"
                                            ItemsSource="{Binding ReasoningFormatOptions}"
                                            SelectedItem="{Binding SelectedModel.ReasoningFormat}"
                                            HorizontalAlignment="Stretch"
                                            ToolTip.Tip="--reasoning-format: parser/output mode for thought tags." />
                                  <TextBlock Grid.Row="2" Grid.Column="0" Text="Reasoning Budget" FontSize="12"
                                             Foreground="#A6ADC8" VerticalAlignment="Center" />
                                  <TextBox Grid.Row="2" Grid.Column="1"
                                           Text="{Binding SelectedModel.ReasoningBudget}"
                                           PlaceholderText="-1 / 0 / N"
                                           HorizontalAlignment="Stretch"
                                           ToolTip.Tip="--reasoning-budget: -1 unlimited, 0 no thinking, N token budget." />
                                </Grid>
                              </Expander>
                            </StackPanel>
                        </StackPanel>
                      </Border>
                    </Expander>

                    <Expander Header="Raw flags (power users)" IsExpanded="False" Margin="0,2,0,0">
                      <Border Classes="card" Margin="0,8,0,0" Padding="14">
                        <StackPanel Spacing="10">
<StackPanel Margin="12" Spacing="10">
                              <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                <TextBlock Grid.Column="0" Text="Raw llama-server flags." FontSize="12" Foreground="#A6ADC8" TextWrapping="Wrap" VerticalAlignment="Center" />
                                <Button Grid.Column="1" Content="Copy" Click="OnCopyExtraArgsClick" ToolTip.Tip="Copy only these raw flags." />
                                <Button Grid.Column="2" Content="Paste" Click="OnPasteExtraArgsClick" ToolTip.Tip="Paste into these raw flags." />
                              </Grid>
                              <TextBox Name="ExtraArgsTextBox"
                                       Text="{Binding SelectedModel.ExtraArgs}"
                                       AcceptsReturn="True"
                                       MinHeight="110"
                                       TextWrapping="Wrap"
                                       KeyDown="OnExtraArgsKeyDown"
                                       GotFocus="OnExtraArgsGotFocus"
                                       PlaceholderText="--rope-scaling yarn --mmproj /path/mmproj.gguf --lora adapter.gguf" />
                            </StackPanel>
                        </StackPanel>
                      </Border>
                    </Expander>


                  
                  </StackPanel>
                </ScrollViewer>
                <Border Grid.Row="2" Padding="16,12" Background="#0F0F17" BorderBrush="#1F1F2E" BorderThickness="0,1,0,0">
                  <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="10">
                    <TextBlock Text="Changes apply to config on Save." FontSize="11" Foreground="#6C7086" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Save" Command="{Binding SaveModelCommand}" Classes="success" Padding="16,8" MinWidth="110"/>
                    <Button Grid.Column="2" Content="Cancel" Command="{Binding CancelModelCommand}" Classes="ghost" Padding="16,8" MinWidth="110" IsVisible="{Binding IsNewModel}"/>
                    <Button Grid.Column="3" Content="Delete" Click="OnDeleteModelClick" Classes="danger" Padding="16,8" MinWidth="110"/>
                  </Grid>
                </Border>
              </Grid>
            </Border>
          </Grid>
        </Grid>

        </Panel>
        <Panel IsVisible="{Binding CurrentView, Converter={x:Static conv:StringEqualsConverter.Instance}, ConverterParameter=matrix}">

        <DockPanel>
          <Border DockPanel.Dock="Top" Padding="24,18" BorderBrush="#1F1F2E" BorderThickness="0,0,0,1" Background="#12121A">
            <StackPanel Spacing="4">
              <TextBlock Text="Matrix" FontSize="20" FontWeight="SemiBold" Foreground="#CDD6F4"/>
              <TextBlock Text="Model loading groups and eviction priority." FontSize="12" Foreground="#6C7086" TextWrapping="Wrap"/>
            </StackPanel>
          </Border>
          <Border Padding="8"><Border Padding="4">        <Grid RowDefinitions="Auto,*" Margin="20">
          <StackPanel Grid.Row="0" Spacing="12" Margin="0,0,0,12">
            <TextBlock Text="Matrix Configuration" FontSize="16" FontWeight="Bold" Foreground="#CDD6F4" />
            <Border Padding="16" Background="#161622" BorderBrush="#313244" BorderThickness="1" CornerRadius="10">
              <StackPanel Spacing="6">
                <TextBlock Text="Model loading groups and eviction priority" FontSize="14" FontWeight="Bold" Foreground="#CDD6F4" />
                <TextBlock Text="Create combinations, then decide what unloads first. Matrix changes are saved automatically to config.yml." FontSize="12" Foreground="#A6ADC8" TextWrapping="Wrap" />
              </StackPanel>
            </Border>
          </StackPanel>

          <TabControl Grid.Row="1" Background="#101018" BorderBrush="#313244">
            <TabItem Header="Combinations">
              <Grid RowDefinitions="Auto,*" Margin="0,14,0,0">
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,0,0,12">
                  <Button Content="+ Add Combination" Command="{Binding AddMatrixCombinationCommand}" Classes="success" Padding="12,6" />
                  <Button Content="Create 'all' Combination" Command="{Binding CreateAllModelsMatrixSetCommand}" Padding="12,6" />
                </StackPanel>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,10,12">
                  <ItemsControl ItemsSource="{Binding MatrixCombinations}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:MatrixCombinationItem">
                        <Border Padding="16" Margin="0,0,0,12" Background="#161622" CornerRadius="8">
                          <StackPanel Spacing="12">
                            <Grid ColumnDefinitions="160,*,Auto" ColumnSpacing="10">
                              <TextBlock Grid.Column="0" Text="Combination name" Foreground="#A6ADC8" VerticalAlignment="Center" />
                              <TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="coding_with_embeddings" />
                              <Button Grid.Column="2" Content="Remove" Command="{Binding RemoveCommand}" Classes="danger" Padding="10,5" />
                            </Grid>
                            <TextBlock Text="Models" FontSize="12" Foreground="#B4BEFE" FontWeight="Bold" />
                            <ItemsControl ItemsSource="{Binding Models}">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:MatrixModelSelectionItem">
                                  <CheckBox IsChecked="{Binding IsSelected}" Margin="0,0,0,6">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                      <TextBlock Text="{Binding Alias}" Foreground="#89B4FA" FontWeight="Bold" />
                                      <TextBlock Text="→" Foreground="#6C7086" />
                                      <TextBlock Text="{Binding ModelId}" Foreground="#CDD6F4" />
                                    </StackPanel>
                                  </CheckBox>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
              </Grid>
            </TabItem>

            <TabItem Header="Eviction">
              <Grid RowDefinitions="Auto,*" Margin="0,14,0,0">
                <StackPanel Grid.Row="0" Spacing="6" Margin="0,0,0,12">
                  <TextBlock Text="Eviction priority" FontSize="14" FontWeight="Bold" Foreground="#CDD6F4" />
                  <TextBlock Text="Choose what unloads first when memory is tight." FontSize="12" Foreground="#A6ADC8" />
                </StackPanel>
                <Border Grid.Row="1" Padding="16" Background="#161622" CornerRadius="10">
                  <Grid RowDefinitions="Auto,*">
                    <Grid Grid.Row="0" ColumnDefinitions="80,*,190,110" ColumnSpacing="12" Margin="0,0,0,8">
                      <TextBlock Grid.Column="0" Text="Alias" FontSize="11" Foreground="#6C7086" />
                      <TextBlock Grid.Column="1" Text="Model" FontSize="11" Foreground="#6C7086" />
                      <TextBlock Grid.Column="2" Text="Priority" FontSize="11" Foreground="#6C7086" />
                      <TextBlock Grid.Column="3" Text="Cost" FontSize="11" Foreground="#6C7086" />
                    </Grid>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                      <ItemsControl ItemsSource="{Binding EvictCosts}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="vm:EvictCostItem">
                            <Grid ColumnDefinitions="80,*,190,110" ColumnSpacing="12" Margin="0,4">
                              <TextBlock Grid.Column="0" Text="{Binding Key}" Foreground="#89B4FA" FontWeight="Bold" VerticalAlignment="Center" />
                              <TextBlock Grid.Column="1" Text="{Binding ModelId}" Foreground="#CDD6F4" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                              <ComboBox Grid.Column="2" ItemsSource="{Binding PriorityOptions}" SelectedItem="{Binding Priority, UpdateSourceTrigger=PropertyChanged}" />
                              <TextBox Grid.Column="3"
                                       Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                       PlaceholderText="cost"
                                       KeyDown="OnEvictCostKeyDown"
                                       TextInput="OnEvictCostTextInput"
                                       TextChanged="OnEvictCostTextChanged" />
                            </Grid>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </ScrollViewer>
                  </Grid>
                </Border>
              </Grid>
            </TabItem>

            <TabItem Header="Advanced YAML">
              <ScrollViewer Margin="0,14,0,0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Border Padding="16" Background="#161622" CornerRadius="10">
                  <StackPanel Spacing="10">
                    <TextBlock Text="Raw vars, sets, and evict costs." FontSize="11" Foreground="#6C7086" />
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="16" RowSpacing="16">
                      <StackPanel Grid.Row="0" Grid.Column="0" Spacing="6">
                        <TextBlock Text="Vars" Foreground="#A6ADC8" />
                        <TextBox Text="{Binding MatrixVarsText, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="140" FontFamily="Consolas, monospace" TextWrapping="Wrap" />
                      </StackPanel>
                      <StackPanel Grid.Row="0" Grid.Column="1" Spacing="6">
                        <TextBlock Text="Sets" Foreground="#A6ADC8" />
                        <TextBox Text="{Binding MatrixSetsText, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="140" FontFamily="Consolas, monospace" TextWrapping="Wrap" />
                      </StackPanel>
                      <StackPanel Grid.Row="1" Grid.Column="0" Spacing="6">
                        <TextBlock Text="Evict costs" Foreground="#A6ADC8" />
                        <TextBox Text="{Binding EvictCostsText, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="110" FontFamily="Consolas, monospace" TextWrapping="Wrap" />
                      </StackPanel>
                    </Grid>
                  </StackPanel>
                </Border>
              </ScrollViewer>
            </TabItem>
          </TabControl>
        </Grid>
      
          </Border></Border>
        </DockPanel>

        </Panel>
        <Panel IsVisible="{Binding CurrentView, Converter={x:Static conv:StringEqualsConverter.Instance}, ConverterParameter=preview}">

        <DockPanel>
          <Border DockPanel.Dock="Top" Padding="24,18" BorderBrush="#1F1F2E" BorderThickness="0,0,0,1" Background="#12121A">
            <StackPanel Spacing="4">
              <TextBlock Text="Config preview" FontSize="20" FontWeight="SemiBold" Foreground="#CDD6F4"/>
              <TextBlock Text="Read-only projection of the generated config.yml." FontSize="12" Foreground="#6C7086" TextWrapping="Wrap"/>
            </StackPanel>
          </Border>
          <Border Padding="8"><Border Padding="4">        <ScrollViewer Padding="20" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <StackPanel Spacing="16">
            <TextBlock Text="Generated config.yml" FontSize="16" FontWeight="Bold" Foreground="#CDD6F4" />
            <TextBlock Text="Preview before saving."
                       FontSize="12" Foreground="#A6ADC8" />
            <Border Padding="16" Background="#161622" CornerRadius="8" BorderBrush="#313244" BorderThickness="1">
              <TextBox Text="{Binding ConfigPreview}"
                       IsReadOnly="True"
                       TextWrapping="Wrap"
                       FontFamily="Consolas, monospace"
                       FontSize="12"
                       Foreground="#A6E3A1"
                       AcceptsReturn="True"
                       Height="450" />
            </Border>
            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
              <Button Content="Save to Disk"
                      Command="{Binding SaveAndPreviewCommand}"
                      Classes="success"
                      Padding="20,10" />
              <Button Content="Reload from Disk"
                      Command="{Binding LoadConfigCommand}"
                      Padding="20,10" />
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      
          </Border></Border>
        </DockPanel>

        </Panel>
        <Panel IsVisible="{Binding CurrentView, Converter={x:Static conv:StringEqualsConverter.Instance}, ConverterParameter=metrics}">

        <DockPanel>
          <Border DockPanel.Dock="Top" Padding="24,18" BorderBrush="#1F1F2E" BorderThickness="0,0,0,1" Background="#12121A">
            <StackPanel Spacing="4">
              <TextBlock Text="Metrics" FontSize="20" FontWeight="SemiBold" Foreground="#CDD6F4"/>
              <TextBlock Text="Live llama-server KPIs and upstream logs." FontSize="12" Foreground="#6C7086" TextWrapping="Wrap"/>
            </StackPanel>
          </Border>
          <Border Padding="8"><Border Padding="4">        <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" Margin="16">
          <!-- Header -->
          <Border Grid.Row="0" Padding="16" Background="#161622" CornerRadius="8" Margin="0,0,0,16">
            <StackPanel Spacing="6">
              <TextBlock Text="llama-server Metrics" FontSize="16" FontWeight="Bold" Foreground="#CDD6F4" />
              <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="#A6ADC8" />
            </StackPanel>
          </Border>

          <!-- Stats cards -->
          <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*" RowDefinitions="Auto" ColumnSpacing="16" Margin="0,0,0,16">
            <Border Grid.Row="0" Grid.Column="0" Padding="20" Background="#161622" CornerRadius="8">
              <StackPanel Spacing="4" HorizontalAlignment="Center">
                <TextBlock Text="Prefill Tokens" FontSize="11" Foreground="#6C7086" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding PrefillTokens}" FontSize="28" FontWeight="Bold" Foreground="#89B4FA" HorizontalAlignment="Center" />
                <TextBlock Text="Total" FontSize="11" Foreground="#A6ADC8" HorizontalAlignment="Center" />
              </StackPanel>
            </Border>
            <Border Grid.Row="0" Grid.Column="1" Padding="20" Background="#161622" CornerRadius="8">
              <StackPanel Spacing="4" HorizontalAlignment="Center">
                <TextBlock Text="Decode Tokens" FontSize="11" Foreground="#6C7086" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding DecodeTokens}" FontSize="28" FontWeight="Bold" Foreground="#A6E3A1" HorizontalAlignment="Center" />
                <TextBlock Text="Total" FontSize="11" Foreground="#A6ADC8" HorizontalAlignment="Center" />
              </StackPanel>
            </Border>
            <Border Grid.Row="0" Grid.Column="2" Padding="20" Background="#161622" CornerRadius="8">
              <StackPanel Spacing="4" HorizontalAlignment="Center">
                <TextBlock Text="Tokens/sec" FontSize="11" Foreground="#6C7086" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding TokensPerSecond, StringFormat={}{0:F1}}" FontSize="28" FontWeight="Bold" Foreground="#FAB387" HorizontalAlignment="Center" />
                <TextBlock Text="Real-time" FontSize="11" Foreground="#A6ADC8" HorizontalAlignment="Center" />
              </StackPanel>
            </Border>
            <Border Grid.Row="0" Grid.Column="3" Padding="20" Background="#161622" CornerRadius="8">
              <StackPanel Spacing="4" HorizontalAlignment="Center">
                <TextBlock Text="Active Slots" FontSize="11" Foreground="#6C7086" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding ActiveSlots}" FontSize="28" FontWeight="Bold" Foreground="#F5C2E7" HorizontalAlignment="Center" />
                <TextBlock Text="Running" FontSize="11" Foreground="#A6ADC8" HorizontalAlignment="Center" />
              </StackPanel>
            </Border>
          </Grid>

          <!-- Loaded Models -->
          <Border Grid.Row="2" Padding="12" Background="#161622" CornerRadius="8" Margin="0,0,0,16">
            <StackPanel Spacing="8">
              <TextBlock Text="Loaded Models" FontSize="12" FontWeight="Bold" Foreground="#CDD6F4" />
              <ItemsControl ItemsSource="{Binding LoadedModels}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Padding="8,4" Background="#45475A" CornerRadius="6" Margin="0,0,4,4">
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="{Binding State}" FontSize="9" FontWeight="Bold" Foreground="#6C7086" />
                        <TextBlock Text="{Binding DisplayName}" FontSize="11" FontWeight="SemiBold" Foreground="#CDD6F4" />
                        <TextBlock Text="{Binding Proxy}" FontSize="10" Foreground="#6C7086" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <!-- Log filter + logs -->
          <Grid Grid.Row="3" RowDefinitions="Auto,*">
            <!-- Filter bar -->
            <Border Grid.Row="0" Padding="10,6" Background="#101018" CornerRadius="8" Margin="0,0,0,8">
              <Grid ColumnDefinitions="24,*,Auto" ColumnSpacing="8">
                <TextBlock Grid.Column="0" Text="🔍" VerticalAlignment="Center" Foreground="#6C7086" FontSize="12" />
                <TextBox Grid.Column="1" Text="{Binding UpstreamLogFilterText, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Filter upstream logs (regex)"
                         Foreground="#CDD6F4" Background="#161622" BorderBrush="#252536" FontSize="11" />
                <Button Grid.Column="2" Content="✕" Command="{Binding ClearLogCommand}" Padding="6,2" FontSize="10" Foreground="#6C7086" />
              </Grid>
            </Border>

            <!-- Log window (full width) -->
            <Border Grid.Row="1" Padding="12" Background="#161622" CornerRadius="8">
              <Grid RowDefinitions="Auto,*">
                <TextBlock Grid.Row="0" Text="Upstream Logs" FontSize="12" FontWeight="Bold" Foreground="#A6E3A1" Margin="0,0,0,6" />
                <Grid Grid.Row="1">
                  <ScrollViewer x:Name="UpstreamLogScrollViewer"
                               VerticalScrollBarVisibility="Auto"
                               HorizontalScrollBarVisibility="Auto">
                    <TextBox x:Name="UpstreamLogTextBox"
                             Text="{Binding UpstreamLogText}"
                             Background="#101018"
                             Foreground="#CDD6F4"
                             IsReadOnly="True"
                             TextWrapping="NoWrap"
                             FontFamily="Consolas, monospace"
                             FontSize="11"
                             AcceptsReturn="True" />
                  </ScrollViewer>

                  <!-- Jump-to-bottom when user has scrolled up -->
                  <Button x:Name="ScrollToBottomButton"
                          Content="↓"
                          ToolTip.Tip="Jump to latest logs"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Bottom"
                          Margin="0,0,16,16"
                          Width="36"
                          Height="36"
                          FontSize="16"
                          FontWeight="Bold"
                          Foreground="#CDD6F4"
                          Background="#45475A"
                          BorderBrush="#89B4FA"
                          BorderThickness="1"
                          CornerRadius="18"
                          Opacity="0.92"
                          IsVisible="False"
                          Click="OnScrollToBottomClick"
                          ZIndex="10" />
                </Grid>
              </Grid>
            </Border>
          </Grid>

          <!-- Footer -->
          <Border Grid.Row="4" Padding="12,8" Background="#101018" BorderBrush="#313244" BorderThickness="0,1,0,0" Margin="0,16,0,0">
            <TextBlock Text="Logs update in real-time. Upstream logs from llama-server via streaming API." FontSize="10" Foreground="#6C7086" />
          </Border>
        </Grid>
      
          </Border></Border>
        </DockPanel>

        </Panel>
        <Panel IsVisible="{Binding CurrentView, Converter={x:Static conv:StringEqualsConverter.Instance}, ConverterParameter=settings}">

        <DockPanel>
          <Border DockPanel.Dock="Top" Padding="24,18" BorderBrush="#1F1F2E" BorderThickness="0,0,0,1" Background="#12121A">
            <StackPanel Spacing="4">
              <TextBlock Text="Settings" FontSize="20" FontWeight="SemiBold" Foreground="#CDD6F4"/>
              <TextBlock Text="Paths, GPU backend and global runtime options." FontSize="12" Foreground="#6C7086" TextWrapping="Wrap"/>
            </StackPanel>
          </Border>
          <Border Padding="8"><Border Padding="4">        <ScrollViewer Padding="20" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <StackPanel Spacing="16">
            <!-- Paths -->
            <Border Padding="16" Background="#161622" CornerRadius="8">
              <StackPanel Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="Paths" FontSize="15" FontWeight="Bold" Foreground="#B4BEFE" />
                  <TextBlock Text="(auto-detected)" FontSize="11" Foreground="#6C7086" />
                </StackPanel>
                <Grid ColumnDefinitions="200,*" RowSpacing="10">
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                  </Grid.RowDefinitions>
                  <DockPanel Grid.Row="0" Grid.Column="0" LastChildFill="False" VerticalAlignment="Center">
                    <TextBlock Text="llama-swap Exe" FontSize="12" Foreground="#A6ADC8"
                               VerticalAlignment="Center" DockPanel.Dock="Left" />
                    <Ellipse Width="8" Height="8" Margin="6,0,0,0" DockPanel.Dock="Left"
                             VerticalAlignment="Center"
                             Fill="{Binding LlamaSwapExeAutoDetected, Converter={x:Static conv:BooleanToBrushConverter.Instance}}"
                             IsVisible="{Binding LlamaSwapExeAutoDetected}" />
                  </DockPanel>
                  <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding LlamaSwapExePath}"
                           PlaceholderText="/path/to/llama-swap" VerticalAlignment="Center" />

                  <DockPanel Grid.Row="1" Grid.Column="0" LastChildFill="False" VerticalAlignment="Center">
                    <TextBlock Text="Config File" FontSize="12" Foreground="#A6ADC8"
                               VerticalAlignment="Center" DockPanel.Dock="Left" />
                    <Ellipse Width="8" Height="8" Margin="6,0,0,0" DockPanel.Dock="Left"
                             VerticalAlignment="Center" Fill="#A6E3A1"
                             IsVisible="{Binding ConfigFileAutoDetected}" />
                  </DockPanel>
                  <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ConfigFilePath}"
                           PlaceholderText="/path/to/config.yml" VerticalAlignment="Center" />

                  <TextBlock Grid.Row="2" Grid.Column="0" Text="llama-server Default" FontSize="12"
                             Foreground="#A6ADC8" VerticalAlignment="Center" />
                  <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding LlamaServerPath}"
                           PlaceholderText="/path/to/llama-server" VerticalAlignment="Center" />
                </Grid>
              </StackPanel>
            </Border>

              <!-- General -->
            <Border Padding="16" Background="#161622" CornerRadius="8">
              <StackPanel Spacing="12">
                <TextBlock Text="General" FontSize="15" FontWeight="Bold" Foreground="#B4BEFE" />
                <Grid ColumnDefinitions="200,*" RowSpacing="10">
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                  </Grid.RowDefinitions>
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="Start Port (${PORT})" FontSize="12"
                             Foreground="#A6ADC8" VerticalAlignment="Center" />
                  <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                    <TextBox Text="{Binding StartPort}" Width="120" HorizontalAlignment="Left" />
                    <TextBlock Text="First llama-server port for ${PORT}." FontSize="10"
                               Foreground="#6C7086" TextWrapping="Wrap" />
                  </StackPanel>

                  <TextBlock Grid.Row="1" Grid.Column="0" Text="Health Check Timeout (s)" FontSize="12"
                             Foreground="#A6ADC8" VerticalAlignment="Center" />
                  <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding HealthCheckTimeout}"
                           Width="120" HorizontalAlignment="Left" />

                  <TextBlock Grid.Row="2" Grid.Column="0" Text="Log Level" FontSize="12"
                             Foreground="#A6ADC8" VerticalAlignment="Center" />
                  <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding LogLevel}"
                           Width="150" HorizontalAlignment="Left" PlaceholderText="debug" />

                  <TextBlock Grid.Row="3" Grid.Column="0" Text="Global TTL (s)" FontSize="12"
                             Foreground="#A6ADC8" VerticalAlignment="Center" />
                  <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding GlobalTtl}"
                           Width="120" HorizontalAlignment="Left" />

                  <TextBlock Grid.Row="4" Grid.Column="0" Text="Send Loading State" FontSize="12"
                             Foreground="#A6ADC8" VerticalAlignment="Center" />
                  <CheckBox Grid.Row="4" Grid.Column="1"
                            IsChecked="{Binding SendLoadingState}"
                            Content="Inject loading updates into streaming responses while a model is loading"
                            Foreground="#CDD6F4"
                            VerticalAlignment="Center" />
                </Grid>
              </StackPanel>
            </Border>

            <!-- GPU Backend -->
            <Border Padding="16" Background="#161622" CornerRadius="8">
              <StackPanel Spacing="12">
                <TextBlock Text="GPU Acceleration" FontSize="15" FontWeight="Bold" Foreground="#B4BEFE" />
                <TextBlock Text="Select which GPU backend to use for llama.cpp. Auto-detection picks the best available." FontSize="12" Foreground="#A6ADC8" TextWrapping="Wrap" />
                <Grid ColumnDefinitions="200,*" RowSpacing="10">
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                  </Grid.RowDefinitions>
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="Preferred Backend" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center" />
                  <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding GpuBackendOptions}" SelectedItem="{Binding SelectedGpuBackend}" />
                  <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding GpuDetectionStatus}" FontSize="11" Foreground="{Binding GpuDetectionStatusColor}" />
                </Grid>
              </StackPanel>
            </Border>

            <!-- CUDA Version (shown when CUDA backend is selected) -->
            <Border Padding="16" Background="#161622" CornerRadius="8" IsVisible="{Binding IsCudaVersionVisible}">
              <StackPanel Spacing="12">
                <TextBlock Text="CUDA Version" FontSize="15" FontWeight="Bold" Foreground="#B4BEFE" />
                <TextBlock Text="llama.cpp bundles its own CUDA runtime DLLs. Choose which build to download." FontSize="12" Foreground="#A6ADC8" TextWrapping="Wrap" />
                <Grid ColumnDefinitions="200,*" RowSpacing="10">
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                  </Grid.RowDefinitions>
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="CUDA Version" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center" />
                  <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding CudaVersionOptions}" SelectedItem="{Binding CudaVersion}" />
                </Grid>
              </StackPanel>
            </Border>

            <!-- Info -->
            <Border Padding="16" Background="#161622" CornerRadius="8">
              <StackPanel Spacing="8">
                <TextBlock Text="Tips" FontSize="13" FontWeight="Bold" Foreground="#B4BEFE" />
                <TextBlock Text="• Matrix uses &amp; for models loaded together" FontSize="11" Foreground="#A6ADC8" />
                <TextBlock Text="• Vars map short names (q, m, d, t, e) to full model IDs" FontSize="11" Foreground="#A6ADC8" />
                <TextBlock Text="• Sets define named combinations" FontSize="11" Foreground="#A6ADC8" />
                <TextBlock Text="• Evict costs control unload priority" FontSize="11" Foreground="#A6ADC8" />
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      
          </Border></Border>
        </DockPanel>

        </Panel>
        <Panel IsVisible="{Binding CurrentView, Converter={x:Static conv:StringEqualsConverter.Instance}, ConverterParameter=updates}">

        <DockPanel>
          <Border DockPanel.Dock="Top" Padding="24,18" BorderBrush="#1F1F2E" BorderThickness="0,0,0,1" Background="#12121A">
            <StackPanel Spacing="4">
              <TextBlock Text="Updates" FontSize="20" FontWeight="SemiBold" Foreground="#CDD6F4"/>
              <TextBlock Text="llama-swap and llama.cpp releases." FontSize="12" Foreground="#6C7086" TextWrapping="Wrap"/>
            </StackPanel>
          </Border>
          <Border Padding="8"><Border Padding="4">        <ScrollViewer Padding="20" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <StackPanel Spacing="16" DataContext="{Binding UpdateViewModel}">
            <!-- Header -->
            <Border Padding="16" Background="#161622" CornerRadius="8">
              <StackPanel Spacing="6">
                <TextBlock Text="llama-swap Update" FontSize="16" FontWeight="Bold" Foreground="#CDD6F4" />
                <TextBlock Text="Download and install the latest llama-swap release from GitHub." FontSize="12" Foreground="#A6ADC8" TextWrapping="Wrap" />
              </StackPanel>
            </Border>

            <!-- Version info -->
            <Border Padding="16" Background="#161622" CornerRadius="8">
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <StackPanel Grid.Column="0" Spacing="6">
                  <Grid ColumnDefinitions="140,*,140,*" ColumnSpacing="12">
                    <TextBlock Grid.Column="0" Text="Current" FontSize="12" Foreground="#6C7086" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="{Binding CurrentVersion}" FontSize="14" FontWeight="Bold" Foreground="#CDD6F4" />
                    <TextBlock Grid.Column="2" Text="Latest" FontSize="12" Foreground="#6C7086" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="3" Text="{Binding LatestVersion}" FontSize="14" FontWeight="Bold" Foreground="#89B4FA" />
                  </Grid>
                  <TextBlock Text="{Binding UpdateStatusText}" FontSize="12" Foreground="{Binding UpdateStatusColor}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                  <Button Content="Check"
                          Command="{Binding CheckCommand}"
                          Padding="14,7"
                          IsEnabled="{Binding CheckButtonEnabled}" />
                  <Button Content="Update"
                          Command="{Binding UpdateCommand}"
                          Classes="success"
                          Padding="14,7"
                          IsEnabled="{Binding UpdateButtonEnabled}" />
                </StackPanel>
              </Grid>
            </Border>

            <!-- Progress -->
            <Border Padding="16" Background="#161622" CornerRadius="8" IsVisible="{Binding IsUpdating}">
              <StackPanel Spacing="10">
                <TextBlock Text="Installation Progress" FontSize="13" FontWeight="Bold" Foreground="#B4BEFE" />
                <ProgressBar Value="{Binding ProgressPercentage}" Maximum="100" Height="8" />
                <TextBlock Text="{Binding ProgressText}" FontSize="11" Foreground="#A6ADC8" TextWrapping="Wrap" />
              </StackPanel>
            </Border>

            <!-- Install info -->
            <Border Padding="16" Background="#161622" CornerRadius="8" BorderBrush="#313244" BorderThickness="1">
              <StackPanel Spacing="4">
                <TextBlock Text="Install Directory" FontSize="12" FontWeight="Bold" Foreground="#A6ADC8" />
                <TextBlock Text="{Binding InstallDirectory}" FontSize="11" Foreground="#6C7086" FontFamily="Consolas, monospace" TextWrapping="Wrap" />
              </StackPanel>
            </Border>

            <!-- llama.cpp Update -->
            <Border Padding="16" Background="#161622" CornerRadius="8">
              <StackPanel Spacing="6">
                <TextBlock Text="llama.cpp Update" FontSize="16" FontWeight="Bold" Foreground="#CDD6F4" />
                <TextBlock Text="Download and install the latest llama.cpp release from GitHub. CUDA version is set in Settings." FontSize="12" Foreground="#A6ADC8" TextWrapping="Wrap" />
              </StackPanel>
            </Border>

            <Border Padding="16" Background="#161622" CornerRadius="8">
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <StackPanel Grid.Column="0" Spacing="6">
                  <Grid ColumnDefinitions="140,*,140,*" ColumnSpacing="12">
                    <TextBlock Grid.Column="0" Text="Current" FontSize="12" Foreground="#6C7086" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="{Binding LlamaCppCurrentVersion}" FontSize="14" FontWeight="Bold" Foreground="#CDD6F4" />
                    <TextBlock Grid.Column="2" Text="Latest" FontSize="12" Foreground="#6C7086" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="3" Text="{Binding LlamaCppLatestVersion}" FontSize="14" FontWeight="Bold" Foreground="#89B4FA" />
                  </Grid>
                  <TextBlock Text="{Binding LlamaCppStatusText}" FontSize="12" Foreground="{Binding LlamaCppStatusColor}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                  <Button Content="Check"
                          Command="{Binding LlamaCppCheckCommand}"
                          Padding="14,7"
                          IsEnabled="{Binding LlamaCppCheckButtonEnabled}" />
                  <Button Content="Update"
                          Command="{Binding LlamaCppUpdateCommand}"
                          Classes="success"
                          Padding="14,7"
                          IsEnabled="{Binding LlamaCppUpdateButtonEnabled}" />
                </StackPanel>
              </Grid>
            </Border>

            <!-- llama.cpp install info -->
            <Border Padding="16" Background="#161622" CornerRadius="8" BorderBrush="#313244" BorderThickness="1">
              <StackPanel Spacing="4">
                <TextBlock Text="llama.cpp Directory" FontSize="12" FontWeight="Bold" Foreground="#A6ADC8" />
                <TextBlock Text="{Binding LlamaCppDirectory}" FontSize="11" Foreground="#6C7086" FontFamily="Consolas, monospace" TextWrapping="Wrap" />
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      
          </Border></Border>
        </DockPanel>

        </Panel>
      </Panel>
    </Border>
  </Grid>
</Window>
