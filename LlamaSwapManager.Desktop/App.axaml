<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="using:LlamaSwapManager.Converters"
             x:Class="LlamaSwapManager.App"
             RequestedThemeVariant="Dark">
  <Application.Resources>
    <conv:BoolToColorConverter x:Key="BoolToColorConverter" TrueColor="#45475A" FalseColor="Transparent" />
    <conv:BoolToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    <SolidColorBrush x:Key="Surface0">#0C0C14</SolidColorBrush>
    <SolidColorBrush x:Key="Surface1">#101018</SolidColorBrush>
    <SolidColorBrush x:Key="Surface2">#161622</SolidColorBrush>
    <SolidColorBrush x:Key="BorderBrushSoft">#1A1A28</SolidColorBrush>
    <SolidColorBrush x:Key="TextPrimary">#CDD6F4</SolidColorBrush>
    <SolidColorBrush x:Key="TextMuted">#6C7086</SolidColorBrush>
    <SolidColorBrush x:Key="Accent">#89B4FA</SolidColorBrush>
  </Application.Resources>
  <Application.Styles>
    <FluentTheme />

    <Style Selector="Button.success">
      <Setter Property="Background" Value="#1B3A2A"/>
      <Setter Property="Foreground" Value="#A6E3A1"/>
      <Setter Property="BorderBrush" Value="#2A4F38"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
    </Style>
    <Style Selector="Button.success:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#234A34"/>
    </Style>

    <Style Selector="Button.danger">
      <Setter Property="Background" Value="#3A1B22"/>
      <Setter Property="Foreground" Value="#F38BA8"/>
      <Setter Property="BorderBrush" Value="#4F2A34"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
    </Style>
    <Style Selector="Button.warning">
      <Setter Property="Background" Value="#3A321B"/>
      <Setter Property="Foreground" Value="#F9E2AF"/>
      <Setter Property="BorderBrush" Value="#4F452A"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
    </Style>
    <Style Selector="Button.ghost">
      <Setter Property="Background" Value="#161622"/>
      <Setter Property="Foreground" Value="#CDD6F4"/>
      <Setter Property="BorderBrush" Value="#252536"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
    </Style>
    <Style Selector="Button.icon-close">
      <Setter Property="Background" Value="#161622"/>
      <Setter Property="Foreground" Value="#CDD6F4"/>
      <Setter Property="BorderBrush" Value="#252536"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="10"/>
    </Style>
    <Style Selector="Button.icon-close:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#2A1B22"/>
      <Setter Property="BorderBrush" Value="#F38BA8"/>
    </Style>
    <Style Selector="Button.nav">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="8"/>
    </Style>
    <Style Selector="Button.nav:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#161622"/>
    </Style>
    <Style Selector="Border.nav-indicator">
      <Setter Property="Width" Value="3"/>
      <Setter Property="Height" Value="18"/>
      <Setter Property="CornerRadius" Value="2"/>
      <Setter Property="Margin" Value="0,0,10,0"/>
      <Setter Property="Background" Value="#89B4FA"/>
    </Style>
    <Style Selector="TextBlock.nav-label">
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Foreground" Value="#CDD6F4"/>
    </Style>
    <Style Selector="TextBlock.nav-section">
      <Setter Property="FontSize" Value="10"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="Foreground" Value="#585B70"/>
      <Setter Property="Margin" Value="18,4,0,6"/>
    </Style>
    <Style Selector="Border.card">
      <Setter Property="Background" Value="#161622"/>
      <Setter Property="BorderBrush" Value="#252536"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Padding" Value="14"/>
    </Style>
    <Style Selector="Border.card:pointerover">
      <Setter Property="BorderBrush" Value="#45475A"/>
    </Style>
    <Style Selector="Border.pill">
      <Setter Property="Background" Value="#1E1E2E"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding" Value="7,3"/>
    </Style>
    <Style Selector="TextBox">
      <Setter Property="Background" Value="#161622"/>
      <Setter Property="Foreground" Value="#CDD6F4"/>
      <Setter Property="BorderBrush" Value="#252536"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="8,6"/>
    </Style>
    <Style Selector="TabControl">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="#252536"/>
    </Style>
    <Style Selector="TabItem">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Foreground" Value="#A6ADC8"/>
      <Setter Property="Padding" Value="12,8"/>
      <Setter Property="Margin" Value="0,0,4,0"/>
    </Style>
    <Style Selector="Expander">
      <Setter Property="Foreground" Value="#CDD6F4"/>
    </Style>
    <Style Selector="ComboBox">
      <Setter Property="Background" Value="#161622"/>
      <Setter Property="Foreground" Value="#CDD6F4"/>
      <Setter Property="BorderBrush" Value="#252536"/>
      <Setter Property="CornerRadius" Value="8"/>
    </Style>
  </Application.Styles>
</Application>
